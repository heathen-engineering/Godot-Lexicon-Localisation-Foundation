[configuration]
entry_symbol = "foundation_lexicon_init"
compatibility_minimum = 4.6

[libraries]

windows.debug.x86_64   = "res://addons/FoundationLexicon/bin/libFoundationLexicon.windows.debug.x86_64.dll"
windows.release.x86_64 = "res://addons/FoundationLexicon/bin/libFoundationLexicon.windows.release.x86_64.dll"

linux.debug.x86_64   = "res://addons/FoundationLexicon/bin/libFoundationLexicon.linux.debug.x86_64.so"
linux.release.x86_64 = "res://addons/FoundationLexicon/bin/libFoundationLexicon.linux.release.x86_64.so"

macos.debug.x86_64   = "res://addons/FoundationLexicon/bin/libFoundationLexicon.macos.debug.x86_64.dylib"
macos.release.x86_64 = "res://addons/FoundationLexicon/bin/libFoundationLexicon.macos.release.x86_64.dylib"
